# OpenObs Environment Configuration
# Copy this file to .env and fill in your values

# Required: JWT secret for authentication (minimum 32 characters)
JWT_SECRET=your-secret-here-minimum-32-characters!!

# Optional: API keys for programmatic access (comma-separated)
API_KEYS=your-api-key

# Required: LLM provider configuration
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-...

# Optional: Seed an admin user on first startup
# SEED_ADMIN=true
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=change-me

# Optional: Datasource URLs
# PROMETHEUS_URL=http://localhost:9090

# Optional: Redis (for production queue/events)
# REDIS_URL=redis://localhost:6379

# Optional: Server config
# PORT=3000
# CORS_ORIGINS=http://localhost:5173
