# OpenObs Environment Configuration
# Copy this file to .env and fill in your values

# Required: JWT secret for authentication (minimum 32 characters)
JWT_SECRET=your-secret-here-minimum-32-characters!!

# Optional: API keys for programmatic access (comma-separated)
API_KEYS=your-api-key

# Optional: Server config
# HOST=0.0.0.0
# PORT=3000
# CORS_ORIGINS=http://localhost:5173
# API_KEY_HEADER=x-api-key
# SESSION_TTL=86400
# NODE_ENV=production

# Optional: Database config
# Leave DATABASE_URL unset to use the default local SQLite persistence.
# DATABASE_URL=postgresql://postgres:change-me@localhost:5432/openobs
# DATABASE_POOL_SIZE=10
# DATABASE_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=false  # Set to "false" to accept self-signed Postgres SSL certs

# Optional: Local data storage
# DATA_DIR=~/.openobs               # Directory for SQLite database and local data storage (default: ./.openobs)
# SQLITE_PATH=/path/to/db.sqlite    # Explicit path to SQLite database file (overrides DATA_DIR)

# Optional: Redis config
# REDIS_URL=redis://localhost:6379
# REDIS_PREFIX=agentic

# Optional: Logging config
# LOG_LEVEL=info
# LOG_FORMAT=json

# Optional: LLM provider configuration
LLM_PROVIDER=anthropic
LLM_API_KEY=your-llm-api-key
# LLM_MODEL=claude-sonnet-4-6
# LLM_FALLBACK_PROVIDER=openai
# ANTHROPIC_API_KEY=sk-ant-...     # Fallback API key for Anthropic (alternative to LLM_API_KEY)
# OPENAI_API_KEY=sk-...            # Fallback API key for OpenAI
# GEMINI_API_KEY=...               # Fallback API key for Google Gemini

# Optional: Seed an admin user on first startup
# SEED_ADMIN=admin                  # Username for auto-created admin account on first startup
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=change-me

# Optional: Datasource URLs
# PROMETHEUS_URL=http://localhost:9090

# Optional: Proactive analysis config
# PROACTIVE_CHECK_INTERVAL_MS=60000
# PROACTIVE_HISTORY_SIZE=100
