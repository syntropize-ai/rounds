{
  "name": "@agentic-obs/root",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "npx tsx bin/start.ts",
    "build": "tsc --build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"packages/*/src/**/*.ts\"",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "testbed:up": "powershell -ExecutionPolicy Bypass -File ./infra/testbed/scripts/up.ps1",
    "testbed:down": "powershell -ExecutionPolicy Bypass -File ./infra/testbed/scripts/down.ps1",
    "testbed:istio:up": "powershell -ExecutionPolicy Bypass -File ./infra/testbed/scripts/up-istio.ps1",
    "testbed:istio:down": "powershell -ExecutionPolicy Bypass -File ./infra/testbed/scripts/down-istio.ps1",
    "testbed:run": "npx tsx testbed/runner.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "drizzle-orm": "^0.45.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
